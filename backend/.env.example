# ============================================================
# FOODSbyme Backend — Environment Variables
# Copy this file to .env and fill in REAL values.
# NEVER commit .env to git — use Railway > Variables for production.
# All secrets marked <generate> must be created fresh (see commands).
# ============================================================

# ── Neon Database ───────────────────────────────────────────
# Get this from: https://console.neon.tech → Your Project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── Flutterwave ─────────────────────────────────────────────
# Get LIVE keys from: https://dashboard.flutterwave.com → Settings → API
# TEST keys will NOT settle real money — always use LIVE keys in production.
# Apply for the "Transfer" product separately to enable cook payouts.
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
# REQUIRED: Set in Flutterwave dashboard → Webhooks → Secret Hash.
# Must match exactly. Generate: openssl rand -hex 32
FLUTTERWAVE_WEBHOOK_HASH=

# ── WhatsApp OTP (primary channel) ──────────────────────────
# Set up: Meta Business Manager → WhatsApp → API Setup
# 1. Create a Meta app at https://developers.facebook.com
# 2. Add "WhatsApp" product and get a phone number
# 3. Create an OTP template (category: Authentication, name: otp_verification)
#    Body: "Your FOODSbyme verification code is {{1}}. Valid for 10 minutes."
# 4. Wait for Meta template approval (~24–48h)
# WHATSAPP_TOKEN         — permanent system user token (not the temp test token)
# WHATSAPP_PHONE_NUMBER_ID — numeric ID shown in WhatsApp → API Setup
# WHATSAPP_TEMPLATE_NAME — your approved template name (default: otp_verification)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=otp_verification

# ── Termii (SMS OTP fallback) ────────────────────────────────
# Used automatically when WhatsApp delivery fails or is not configured.
# Get from: https://accounts.termii.com → Settings → API Key
TERMII_API_KEY=
TERMII_SENDER_ID=FOODSbyme

# ── Customer support WhatsApp Business ──────────────────────
# The WhatsApp Business number customers can message for support.
# Used in app support links (wa.me/...) — not for OTP delivery.
WHATSAPP_BUSINESS_NUMBER=+2348072350602

# ── Cloudinary (file uploads) ───────────────────────────────
# Get these from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Logistics ───────────────────────────────────────────────
LOGISTICS_PROVIDER=
KWIK_API_KEY=
SENDBOX_API_KEY=

# ── Fez Delivery ─────────────────────────────────────────────
# Dashboard: fezdelivery.co → Developers → Manage API Key / Update Secret Key
# Sandbox: https://apisandbox.fezdelivery.co/v1
# Production: https://api.fezdelivery.co/v1
# Webhook: paste https://foodsbyme-api-production.up.railway.app/api/delivery/webhook
#          into fezdelivery.co → Developers → Manage Webhook
FEZ_BASE_URL=https://apisandbox.fezdelivery.co/v1
FEZ_API_KEY=
FEZ_SENDER_NAME=FOODSbyme
FEZ_SENDER_ADDRESS=Lagos, Nigeria
FEZ_SENDER_PHONE=

# ── Server ──────────────────────────────────────────────────
PORT=3000
EXPO_PUBLIC_API_URL=https://foodsbyme-api-production.up.railway.app
NEXT_PUBLIC_API_URL=https://foodsbyme-api-production.up.railway.app

# ── Security ────────────────────────────────────────────────
# REQUIRED: Minimum 32 bytes. Generate: openssl rand -hex 32
# ROTATE THIS: the previous JWT_SECRET was committed to git and must be replaced.
JWT_SECRET=
# REQUIRED: Used to encrypt NIN at rest. Generate: openssl rand -hex 32
NIN_ENCRYPTION_KEY=
FACEBOOK_APP_SECRET=

# ── TikTok Login Kit ─────────────────────────────────────────
# Get these from: https://developers.tiktok.com → your app → Manage app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Twitter / X OAuth 2.0 ────────────────────────────────────
# Create an app at: https://developer.twitter.com → Projects & Apps
# Enable OAuth 2.0, set callback URL: https://foodsbyme-api-production.up.railway.app/api/social-verify/oauth/twitter/callback
# Required scopes: tweet.read users.read
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Instagram Business Login ──────────────────────────────────
# Create a Meta app at: https://developers.facebook.com
# Add "Instagram" product → set Valid OAuth Redirect URI:
#   https://foodsbyme-api-production.up.railway.app/api/social-verify/oauth/instagram/callback
# Only works for Professional (Business or Creator) Instagram accounts.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── Google OAuth (YouTube verification) ──────────────────────
# Create an OAuth 2.0 Client ID at: https://console.cloud.google.com
# Authorised redirect URI: https://foodsbyme-api-production.up.railway.app/api/social-verify/oauth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Worker secret (internal cron endpoint auth) ───────────────
# Any random string — used to secure /auto-release, /sla/worker, /reliability/compute-worker
# Generate: openssl rand -hex 32
WORKER_SECRET=

# ── Resend (transactional email) ─────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# ── Platform ────────────────────────────────────────────────
PLATFORM_NAME=FOODSbyme
SUPPORT_EMAIL=hello@foodsbyme.com
PLATFORM_URL=https://foodsbyme.com
APP_BASE_URL=https://foodsbyme-api-production.up.railway.app
