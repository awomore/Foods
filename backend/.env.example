# ============================================================
# FOODSbyme Backend — Environment Variables
# Copy this file to .env and fill in REAL values.
# NEVER commit .env to git — use Railway > Variables for production.
# All secrets marked <generate> must be created fresh (see commands).
# ============================================================

# ── Neon Database ───────────────────────────────────────────
# Get this from: https://console.neon.tech → Your Project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── Flutterwave ─────────────────────────────────────────────
# Get LIVE keys from: https://dashboard.flutterwave.com → Settings → API
# TEST keys will NOT settle real money — always use LIVE keys in production.
# Apply for the "Transfer" product separately to enable cook payouts.
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
# REQUIRED: Set in Flutterwave dashboard → Webhooks → Secret Hash.
# Must match exactly. Generate: openssl rand -hex 32
FLUTTERWAVE_WEBHOOK_HASH=

# ── Termii (SMS OTP) ────────────────────────────────────────
# Get this from: https://accounts.termii.com → Settings → API Key
# Leave blank in dev mode — OTPs will print to console instead
TERMII_API_KEY=
TERMII_SENDER_ID=FOODSbyme

# ── Cloudinary (file uploads) ───────────────────────────────
# Get these from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Logistics ───────────────────────────────────────────────
LOGISTICS_PROVIDER=
KWIK_API_KEY=
SENDBOX_API_KEY=

# ── Server ──────────────────────────────────────────────────
PORT=3000
EXPO_PUBLIC_API_URL=https://foodsbyme-api-production.up.railway.app
NEXT_PUBLIC_API_URL=https://foodsbyme-api-production.up.railway.app

# ── Security ────────────────────────────────────────────────
# REQUIRED: Minimum 32 bytes. Generate: openssl rand -hex 32
# ROTATE THIS: the previous JWT_SECRET was committed to git and must be replaced.
JWT_SECRET=
# REQUIRED: Used to encrypt NIN at rest. Generate: openssl rand -hex 32
NIN_ENCRYPTION_KEY=
FACEBOOK_APP_SECRET=

# ── TikTok Login Kit ─────────────────────────────────────────
# Get these from: https://developers.tiktok.com → your app → Manage app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Google OAuth (YouTube verification) ──────────────────────
# Create an OAuth 2.0 Client ID at: https://console.cloud.google.com
# Authorised redirect URI: https://foodsbyme-api-production.up.railway.app/api/social-verify/oauth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Worker secret (internal cron endpoint auth) ───────────────
# Any random string — used to secure /auto-release, /sla/worker, /reliability/compute-worker
# Generate: openssl rand -hex 32
WORKER_SECRET=

# ── Resend (transactional email) ─────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# ── Platform ────────────────────────────────────────────────
PLATFORM_NAME=FOODSbyme
SUPPORT_EMAIL=hello@foodsbyme.com
PLATFORM_URL=https://foodsbyme.com
APP_BASE_URL=https://foodsbyme-api-production.up.railway.app
