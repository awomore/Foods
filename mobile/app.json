{
  "expo": {
    "name": "FOODS",
    "slug": "foodsbyme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foodsbyme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#1A1009"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skodztest.foodsbyme"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A1009"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.skodztest.foodsbyme",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E8924A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FOODS to access your photos for dish and profile photos.",
          "cameraPermission": "Allow FOODS to take photos of your dishes."
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FOODS to use your location to show nearby cooks.",
          "locationWhenInUsePermission": "Allow FOODS to use your location to show nearby cooks."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d985c751-2699-42c9-849a-439073e4a65e"
      }
    }
  }
}
