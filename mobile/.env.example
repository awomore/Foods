# ============================================================
# FOODSbyme Mobile — Environment Variables
# Copy this file to .env and fill in REAL values.
# NEVER commit .env to git.
# ============================================================

# ── Flutterwave ──────────────────────────────────────────────
# LIVE public key from: https://dashboard.flutterwave.com → Settings → API
# TEST keys will NOT accept real card payments.
# ROTATE: the previous key was committed to git.
EXPO_PUBLIC_FLUTTERWAVE_PK=FLWPUBK_LIVE-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend API ──────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://foodsbyme-api-production.up.railway.app

# ── Google Maps / Places ─────────────────────────────────────
# Enable "Places API" and "Maps SDK for Android" in Google Cloud Console.
# Restrict the key to this app's package name (com.skodztest.foodsbyme).
# ROTATE: the previous key was committed to git.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_KEY=

# ── Expo Push Notifications ──────────────────────────────────
# From: expo.dev → your project → Project ID
EXPO_PUBLIC_PROJECT_ID=

# ── Sentry (crash reporting) ─────────────────────────────────
# From: sentry.io → project → Settings → Client Keys (DSN)
# Leave blank to disable — app will not crash.
# ROTATE: the previous DSN was committed to git.
EXPO_PUBLIC_SENTRY_DSN=
