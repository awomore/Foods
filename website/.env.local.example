# ─────────────────────────────────────────────────────────
# FOODSbyme Website — Environment Variables
# Copy this file to .env.local for local dev.
# Add all variables to your Vercel project environment settings.
# ─────────────────────────────────────────────────────────

# Resend API key — used to email fleet partner applications to partnerships@foodsbyme.com
# 1. Sign up free at https://resend.com
# 2. Create an API key under API Keys → Add API Key
# 3. Paste it below (and in Vercel → Settings → Environment Variables)
# Without this key the form falls back to opening the visitor's email client.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
